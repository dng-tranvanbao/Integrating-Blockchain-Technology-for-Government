# AI Legislative Assistant Portal Configuration
# Duplicate this file as '.env' and fill in your API key/token.

# AI Provider: 'github', 'gemini', or 'openai'
VITE_AI_PROVIDER=github

# API Key or Token
# - For 'github': paste your GitHub Personal Access Token (PAT) - no scopes needed.
# - For 'gemini': paste your Google AI Studio API Key.
# - For 'openai': paste your OpenAI API Key.
VITE_AI_API_KEY=

# Default Model name depending on the provider:
# - For github: gpt-4o-mini, gpt-4o, meta-llama-3.1-405b-instruct, cohere-command-r-plus, phi-3-medium-instruct
# - For gemini: gemini-2.5-flash, gemini-2.5-pro, gemini-1.5-flash
# - For openai: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
VITE_AI_MODEL=gpt-4o-mini
